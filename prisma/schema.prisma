generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model address {
  id         Int      @id @default(autoincrement())
  student_id Int      @unique
  location   String
  house      String?
  info       String?
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model parent {
  id         Int      @id @default(autoincrement())
  student_id Int
  name       String   @db.VarChar(250)
  email      String   @unique @db.VarChar(500)
  created_at DateTime @default(now()) @db.Timestamp(6)
  student    student  @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model student {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(250)
  email           String            @unique @db.VarChar(500)
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  parent          parent[]
  student_subject student_subject[]
}

model student_subject {
  id         Int      @id @default(autoincrement())
  student_id Int
  subject_id Int
  created_at DateTime @default(now()) @db.Timestamp(6)
  student    student  @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject    subject  @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model subject {
  id              Int               @id @default(autoincrement())
  name            String
  code            String
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  student_subject student_subject[]
}

model player {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String           @db.VarChar(250)
  email           String           @unique @db.VarChar(500)
  created_at      DateTime         @default(now()) @db.Timestamp(6)
  updated_at      DateTime         @default(now()) @db.Timestamp(6)
  player_password player_password?
  games           game[]
}

model player_password {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  player_id  String   @unique @db.Uuid
  password   String
  updated_at DateTime @default(now()) @db.Timestamp(6)
  player     player   @relation(fields: [player_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model game {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  player_id       String   @db.Uuid
  status          String   @default("active")
  phase           String   @default("preflop")
  player_cards    String
  pc_cards        String
  community_cards String   @default("[]")
  deck            String
  pot             Int      @default(0)
  player_chips    Int      @default(2000)
  pc_chips        Int      @default(2000)
  player_bet      Int      @default(0)
  pc_bet          Int      @default(0)
  winner          String?
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @default(now()) @db.Timestamp(6)
  player          player   @relation(fields: [player_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
